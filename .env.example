# Docker image tags
IMAGE_TAG=latest

# Host ports
FRONTEND_PORT=5173
BACKEND_PORT=5007

# Frontend build-time API origin.
# "/" makes the production Nginx frontend proxy /api to the backend service.
VITE_API_ORIGIN=/

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
Frontend__LoginUrl=http://localhost:5173/login

# Database
ConnectionStrings__DefaultConnection=Server=host.docker.internal;Port=3306;Database=ems;User=ems_user;Password=change_me;SslMode=None;

# JWT
Jwt__Key=change_me_to_a_long_random_secret_at_least_32_characters
Jwt__Issuer=EMS
Jwt__Audience=EMSUsers

# Email
EmailSettings__Host=smtp.gmail.com
EmailSettings__Port=587
EmailSettings__Username=your-email@example.com
EmailSettings__Password=change_me
