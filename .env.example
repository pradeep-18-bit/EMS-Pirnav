# Docker image tags
IMAGE_TAG=latest

# Host ports
FRONTEND_PORT=5173
BACKEND_PORT=5007

# Frontend build-time API origin.
# Docker default uses the frontend Nginx proxy, which routes /api to backend:8080.
# Local Vite dev reads Frontend/EMS/.env.development instead.
# EC2 direct backend option: http://your-ec2-public-ip:5007
VITE_API_ORIGIN=/

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
Frontend__LoginUrl=http://localhost:5173/login
# Use "*" for JWT-only APIs, or a semicolon list such as:
# http://localhost:5173;http://localhost:5174;http://your-ec2-public-ip:5173
Cors__AllowedOrigins=*

# Database
ConnectionStrings__DefaultConnection=Server=host.docker.internal;Port=3306;Database=ems;User=ems_user;Password=change_me;SslMode=None;

# JWT
Jwt__Key=change_me_to_a_long_random_secret_at_least_32_characters
Jwt__Issuer=EMS
Jwt__Audience=EMSUsers

# Email
EmailSettings__Host=smtp.gmail.com
EmailSettings__Port=587
EmailSettings__Username=your-email@example.com
EmailSettings__Password=change_me
