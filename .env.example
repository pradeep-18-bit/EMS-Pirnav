# Docker image tags
IMAGE_TAG=latest

# Host ports
FRONTEND_PORT=5173
BACKEND_PORT=5007
FRONTEND_LOGIN_URL=http://localhost:5173/login

# Frontend build-time API origin.
# "/" makes the production Nginx frontend proxy /api to the backend service.
VITE_API_ORIGIN=/

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production

# Database
DB_CONNECTION_STRING=Server=host.docker.internal;Port=3306;Database=ems;User=ems_user;Password=change_me;SslMode=None;

# JWT
JWT_KEY=change_me_to_a_long_random_secret_at_least_32_characters
JWT_ISSUER=EMS
JWT_AUDIENCE=EMSUsers

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@example.com
EMAIL_PASSWORD=change_me
